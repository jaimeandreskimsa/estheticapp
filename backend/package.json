{
  "name": "esthetic-app-backend",
  "version": "0.1.0",
  "description": "Backend API - Ficha Clínica Electrónica Medicina Estética",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "migrate": "typeorm migration:run -d src/database/dataSource.ts",
    "migrate:generate": "typeorm migration:generate",
    "seed": "tsx src/database/seeds/index.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "docs": "swagger-cli bundle src/swagger.yaml -o docs/api.json"
  },
  "keywords": [
    "healthcare",
    "medicine",
    "clinic",
    "electronic-health-record",
    "chile"
  ],
  "author": "Esthetic App",
  "license": "PROPRIETARY",
  "dependencies": {
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "typeorm": "^0.3.18",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "validator": "^13.11.0",
    "multer": "^1.4.5-lts.1",
    "aws-sdk": "^2.1515.0",
    "openai": "^4.24.0",
    "sharp": "^0.32.6",
    "axios": "^1.6.5",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.11",
    "@types/validator": "^13.11.7",
    "@types/uuid": "^9.0.7",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "prettier": "^3.1.1"
  }
}
